# Общие
NODE_ENV=development
APP_ENV=development

# База данных
DATABASE_URL=file:./prisma/dev.db

# Backend API
PORT=8080
BACKEND_PUBLIC_URL=https://api.example.com
MINI_APP_URL=https://username.github.io/medicupe/
JWT_INTERNAL_SECRET=replace_with_long_random_secret
CORS_ALLOWED_ORIGINS=https://pofegistek.github.io,http://localhost:5173,http://127.0.0.1:5173
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20

# Telegram
TELEGRAM_BOT_TOKEN=123456789:REPLACE_WITH_REAL_TOKEN
TELEGRAM_WEBAPP_BOT_TOKEN=123456789:REPLACE_WITH_REAL_TOKEN
ADMIN_TELEGRAM_ID=123456789
ADMIN_TELEGRAM_IDS=123456789,987654321

# Frontend
VITE_API_BASE_URL=https://api.example.com/api
VITE_BASE_PATH=/
